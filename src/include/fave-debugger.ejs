<section class="debugger" id="debugger">
  <style>
    .debugger {position: fixed;width: 100%;height: 100vh;top: 0;left: 0;visibility: collapse;pointer-events: none;z-index: 3999;}
    .debugger .btn_area {position:absolute ;bottom: 134px;left:10px;z-index: 3999;}
    .debugger .btn_area button{border: 1px solid #ccc;border-radius: 10px;background-color: #ccc;color: #000;padding: 10px;cursor: pointer;pointer-events:all;display: block;margin-top: 5px;}
    .debugger .btn_area button:hover{background-color: #fff;}
    .debugger .container { position: relative;margin: 0 auto;padding-left: min(6.25vw, 120px);padding-right: min(6.25vw, 120px);max-width: 1680px;visibility: collapse;}

    .debugger .content {background-color: rgba(255,192,203,.15);height: 100vh}
    .debugger .row {box-sizing: border-box;display: flex;flex: 0 1 auto;flex-direction: row;flex-wrap: wrap;margin-left: calc(100% / 70 * -1);margin-right: calc(100% / 70 * -1);}


    .col-1{box-sizing: border-box;flex: 0 0 auto;padding-left: calc(100% / 70 * 1);padding-right: calc(100% / 70 * 1);}
    .col-1 {
      flex-basis: calc(100% / 12 * 1);
      max-width: calc(100% / 12 * 1);
    }
    .fave.grid8 .debugger .container { max-width: 1104px;}
    .fave.grid8 .debugger .row{margin-left:  calc(100% / 46 * -1);margin-right:  calc(100% / 46 * -1);}
    .fave.grid8 .col-1 {
      padding-left:  calc(100% / 46 * 1);
      padding-right:  calc(100% / 46 * 1);
      flex-basis: calc(100% / 8 * 1);
      max-width: calc(100% / 8 * 1);
    }
    
    @media all and (max-width: 1200px){
      /* .debugger .container {padding-left: 50px;padding-right: 50px;}
      .fave.grid8 .debugger .container { padding: 0 150px;max-width: 1200px;} */
      
    }
    @media all and (max-width: 1023px) {
      .debugger .container {padding-left: 50px;padding-right: 50px;}
    }
    @media all and (max-width: 768px) {
      .debugger .container {padding-left: 20px;padding-right: 20px;}
      .col-1{display: none;}
      .col-1:nth-child(1),.col-1:nth-child(2),
      .col-1:nth-child(3),.col-1:nth-child(4){display: block;max-width: calc(100% / 4 * 1);flex-basis:calc(100% / 4 * 1);padding-left: 10px;padding-right: 10px;}
      .debugger .row{margin-left: -10px;margin-right: -10px;}
      
    }
    
    .fave .debugger{visibility: visible}
    .fave.dev .debugger .container{visibility: visible}

