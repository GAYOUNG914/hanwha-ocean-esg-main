<script>
  const dev  = window.location.hostname;
  const pp = document.querySelector('#buttonGuide')

  if(dev == 'localhost') {
    document.body.classList.add('fave');
    faveGuide();
  }else {
    document.body.classList.remove('fave');
    document.querySelector('#debugger').remove();
    document.querySelector('#fontGuide').remove();
    document.querySelector('#buttonGuide').remove();
  }

  function faveGuide(){
    const fontGuide = document.querySelectorAll('#fontGuide .container div');
    const textArea = document.createElement('textarea');   
    fontGuide.forEach((_i) => {
      _i.addEventListener('click', () => {
        textArea.textContent = _i.querySelector('span').innerText.split('.')[1]
        document.body.append(textArea); 
        textArea.select();
        document.execCommand('copy');
        textArea.remove(); 
      })
    });
    const toggleBtnGuid = document.querySelector(".toggleBtnGuid")
    toggleBtnGuid.addEventListener('click', function(){
      if(!document.body.classList.contains('dev_button')){
        document.body.classList.add('dev_button');
        hoverRippleDev()
      }else{
        const btn = document.querySelectorAll("[hover='ripple']")

        btn.forEach(_el => {
          _el.addEventListener('mouseenter', (e) => {
            const x = e.pageX - _el.offsetLeft
            const y = e.pageY - _el.offsetTop
            _el.style.setProperty('--x', x + 'px')
            _el.style.setProperty('--y', y + 'px')
          })

        })
        document.body.classList.remove('dev_button');
      }
    })

    function hoverRippleDev() {
      const btnP = document.querySelector("#buttonGuide")
      const btn = btnP.querySelectorAll("[hover='ripple']")

      btn.forEach(_el => {
        _el.addEventListener('mouseenter', (e) => {
          const x = e.pageX - _el.offsetLeft - btnP.offsetLeft - window.scrollX
          const y = e.pageY - _el.offsetTop  - btnP.offsetTop - window.scrollY
          _el.style.setProperty('--x', x + 'px')
          _el.style.setProperty('--y', y + 'px')
        })
      })
    }   
  }
  
</script>